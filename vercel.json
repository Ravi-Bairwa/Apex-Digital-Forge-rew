{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home/", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/services.html", "destination": "/services", "permanent": true },
    { "source": "/pricing.html", "destination": "/pricing", "permanent": true },
    { "source": "/process.html", "destination": "/process", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/blog.html", "destination": "/blog", "permanent": true }
  ],
  "routes": [
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/pricing", "dest": "/pricing.html" },
    { "src": "/process", "dest": "/process.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
